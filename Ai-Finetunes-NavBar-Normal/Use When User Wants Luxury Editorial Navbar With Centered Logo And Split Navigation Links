<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>02 - Logo Center Navbar</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Montserrat:wght@400;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Montserrat', sans-serif; background: #faf8f5; }

  nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0 40px;
    height: 80px;
    background: #fff;
    border-bottom: 1px solid #e8e2d9;
  }

  .nav-left, .nav-right {
    display: flex;
    gap: 32px;
    list-style: none;
    align-items: center;
  }
  .nav-right { justify-content: flex-end; }

  .nav-left a, .nav-right a {
    color: #555;
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-left a:hover, .nav-right a:hover { color: #b5895a; }

  .logo-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    gap: 2px;
  }
  .logo-center img { height: 42px; width: 42px; object-fit: contain; }
  .logo-center span {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #2c2c2c;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 4px;
  }
  .hamburger span {
    display: block;
    width: 24px;
    height: 1.5px;
    background: #2c2c2c;
    transition: all 0.3s ease;
  }
  .hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  .mobile-menu {
    display: none;
    flex-direction: column;
    background: #fff;
    border-top: 1px solid #e8e2d9;
    padding: 24px 40px;
    gap: 0;
  }
  .mobile-menu.open { display: flex; }
  .mobile-menu a {
    color: #555;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 14px 0;
    border-bottom: 1px solid #f0ede8;
    transition: color 0.2s;
  }
  .mobile-menu a:hover { color: #b5895a; }

  @media (max-width: 768px) {
    nav { grid-template-columns: 1fr auto; }
    .nav-left, .nav-right:not(.show-mobile) { display: none; }
    .hamburger { display: flex; }
  }

  .demo-content {
    padding: 60px 40px;
    text-align: center;
    color: #777;
    font-size: 0.9rem;
  }
  .label {
    display: inline-block;
    border: 1px solid #b5895a;
    color: #b5895a;
    padding: 5px 16px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
</style>
</head>
<body>

<nav>
  <ul class="nav-left">
    <li><a href="#">Collections</a></li>
    <li><a href="#">About</a></li>
  </ul>

  <a href="#" class="logo-center">
    <img src="https://raw.githubusercontent.com/testingtestcodeai-cpu/L/refs/heads/main/file_00000000d44c71fab450bdb269c872fe.png" alt="Logo">
    <span>Maison</span>
  </a>

  <ul class="nav-right">
    <li><a href="#">Journal</a></li>
    <li><a href="#">Contact</a></li>
    <button class="hamburger" id="ham" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </ul>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <a href="#">Collections</a>
  <a href="#">About</a>
  <a href="#">Journal</a>
  <a href="#">Contact</a>
</div>

<div class="demo-content">
  <div class="label">Layout 02</div>
  <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.2rem;color:#2c2c2c;margin-bottom:8px;">Logo Center Navbar</h2>
  <p>Split links left and right with the logo perfectly centered — classic luxury editorial layout.</p>
</div>

<script>
  const ham = document.getElementById('ham');
  const menu = document.getElementById('mobileMenu');
  ham.addEventListener('click', () => {
    ham.classList.toggle('open');
    menu.classList.toggle('open');
  });
</script>
</body>
</html>
